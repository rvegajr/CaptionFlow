PORT=3000
DATABASE_URL=postgresql://captionflow:captionflow@localhost:5432/captionflow
BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-at-least-32-characters-long-secret

# ───────────────────────────────────────────────────────────────────────────────
# Outbound email (magic-link sign-in)
#
# Adapter priority: Noctusoft > Resend > Fake (dev-only)
# Set NOCTUSOFT_API_KEY (preferred) or RESEND_API_KEY. FROM_EMAIL must be on a
# verified sender domain — for Noctusoft, see the verified domain list in
# docs/NOCTUSOFT_RELAY.md.
# ───────────────────────────────────────────────────────────────────────────────

# Noctusoft Communication Relay deploy key (nsins_dk_*).
# When set, magic-link emails are sent via api.sendgrid.noctusoft.com and
# Google Translate calls are routed through googleapis.noctusoft.com.
NOCTUSOFT_API_KEY=
# Display name for outbound emails. Defaults to "CaptionFlow".
NOCTUSOFT_FROM_NAME=CaptionFlow

# Legacy: direct Resend integration. Used only if NOCTUSOFT_API_KEY is unset.
RESEND_API_KEY=
FROM_EMAIL=

# ───────────────────────────────────────────────────────────────────────────────
# LTI 1.3
# ───────────────────────────────────────────────────────────────────────────────

LTI_ENCRYPTION_KEY=
DISABLE_LTI=false
# Comma-separated list of origins allowed to embed CaptionFlow in iframes
# (for LMS integration). Examples:
#   *.instructure.com,*.blackboard.com,*.moodlecloud.com,*.brightspace.com
LMS_FRAME_ANCESTORS=

# ───────────────────────────────────────────────────────────────────────────────
# Caption translation (DeepL primary → Google fallback → mock)
# ───────────────────────────────────────────────────────────────────────────────

DEEPL_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

NODE_ENV=development
